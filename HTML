<head>
  <title>Precision Tools Inc.</title>
  <style>
    body { margin: 0; font-family: Arial, sans-serif; background: #f4f4f4; }
    .header { position: sticky; top: 0; background: #0d1b2a; padding: 15px 0; }
    .container { width: 90%; margin: auto; }
    .nav-container { display: flex; justify-content: space-between; align-items: center; }
    .logo { color: white; font-size: 24px; font-weight: bold; }
    .logo span { color: #00b4d8; }
    .nav-links { list-style: none; display: flex; gap: 20px; margin: 0; padding: 0; }
    .nav-links a { color: white; text-decoration: none; }
    .hero { background: linear-gradient(rgba(0,0,0,0.5),rgba(0,0,0,0.5)), url('https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=1200&q=80'); background-size: cover; background-position: center; color: white; text-align: center; padding: 100px 20px; }
    .hero h1 { font-size: 40px; margin-bottom: 10px; }
    .hero p { font-size: 18px; margin-bottom: 20px; }
    .btn { background: #00b4d8; color: white; padding: 12px 20px; text-decoration: none; border: none; border-radius: 5px; cursor: pointer; }
    .section { padding: 50px 0; }
    .section h2 { text-align: center; margin-bottom: 30px; color: #0d1b2a; }
    .team-grid { display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; }
    .card { background: white; width: 250px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.2); text-align: center; padding: 20px; }
    .card img { width: 100px; height: 100px; border-radius: 50%; }
    .card h3 { margin: 15px 0 5px; }
    .card p { color: #555; }
    .contact-form { max-width: 500px; margin: auto; background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.2); }
    .contact-form input, .contact-form textarea { width: 100%; padding: 10px; margin: 10px 0; border: 1px solid #ccc; border-radius: 5px; }
    .footer { background: #0d1b2a; color: white; text-align: center; padding: 15px 0; margin-top: 30px; }
    @media(max-width: 768px) {
      .nav-container { flex-direction: column; gap: 10px; }
      .nav-links { flex-direction: column; align-items: center; }
      .hero h1 { font-size: 30px; }
    }
  </style>
</head>
<body>

  <header class="header">
    <div class="container nav-container">
      <div class="logo">Precision<span>Tools</span></div>
      <nav>
        <ul class="nav-links">
          <li><a href="#home">Home</a></li>
          <li><a href="#about">About</a></li>
          <li><a href="#team">Team</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <section class="hero" id="home">
    <div class="container">
      <h1>Precision Tools Inc.</br>Manufacturing Excellence You Can Trust</h1>
      <p>We deliver high-quality industrial tools and precision manufacturing solutions for businesses that value </br> performance, durability, and reliability.</p>
      <a href="#contact" class="btn">Get a Free Consultation</a>
    </div>
  </section>

  <section class="section" id="about">
    <div class="container">
      <h2>About Precision Tools Inc.</h2>
      <p style="text-align:center;">
       Precision Tools Inc. is a trusted local manufacturing company known for quality workmanship, advanced technology, and dependable service.</br>
      We specialize in producing precision tools and industrial components that help businesses improve productivity and maintain high standards.</br>
      Our team focuses on innovation, accuracy, and customer satisfaction in every project we handle.
      </p>
    </div>
  </section>

  <section class="section" id="team">
    <div class="container">
      <h2>Meet the Team</h2>
      <div class="team-grid">
        <div class="card">
          <img src="https://via.placeholder.com/100" alt="Manager">
          <h3>John Anderson</h3>
          <p>Production Manager</p>
        </div>
        <div class="card">
          <img src="https://via.placeholder.com/100" alt="Engineer">
          <h3>Sarah Mitchell</h3>
          <p>Design Engineer</p>
        </div>
        <div class="card">
          <img src="https://via.placeholder.com/100" alt="Supervisor">
          <h3>David Carter</h3>
          <p>Quality Supervisor</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="contact">
    <div class="container">
      <h2>Contact Us</h2>
      <form class="contact-form" onsubmit="return validateForm()">
        <input type="text" id="name" placeholder="Enter your name">
        <input type="email" id="email" placeholder="Enter your email">
        <textarea id="message" rows="5" placeholder="Enter your message"></textarea>
        <button type="submit" class="btn">Send Message</button>
      </form>
    </div>
  </section>

  <footer class="footer">
    <p>© Aaradhy 2026 Precision Tools Inc. All Rights Reserved.</p>
  </footer>

  <script>
    function validateForm() {
      let name = document.getElementById("name").value;
      let email = document.getElementById("email").value;
      let message = document.getElementById("message").value;

      if (name == "" || email == "" || message == "") {
        alert("Please fill all fields");
        return false;
      }

      alert("Form submitted successfully");
      return true;
    }
  </script>

</body>
</html>
